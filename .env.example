# MySQL（Go 后端使用，默认 root:password@tcp(localhost:3306)/agent_marketplace）
DATABASE_URL="root:password@tcp(localhost:3306)/agent_marketplace?charset=utf8mb4&parseTime=True"

# Prisma 需要 mysql:// 格式（npx prisma db push / db:seed 用）
DATABASE_PRISMA_URL="mysql://root:password@localhost:3306/agent_marketplace"

# 开发时若 dev 跑在 3001
NEXTAUTH_URL="http://localhost:3001"
DEMO_AGENT_BASE_URL="http://localhost:3001/api/demo-agent/invoke"

# 种子运行后会输出，加入以启用 Demo Agent 回执提交
PLATFORM_DEMO_SECRET="run-seed-to-get-this"
PLATFORM_SIGNING_SECRET="change-in-production"

# 小红的编排 Agent 内部调用 Web Analyzer / Report Builder 时使用（需小红的 API Key）
# 种子首次运行会输出 ORCHESTRATOR_BUYER_API_KEY，或使用控制台创建的 buyer 的 Key
ORCHESTRATOR_BUYER_API_KEY="sk_live_xxx"

# 人生 Agent 聊天 AI 能力（可选）
# Go 后端启动时会自动加载项目根目录或 backend/ 下的 .env
# 配置后聊天回复由 LLM 生成，未配置则使用模板回复
#
# Docker Compose：backend 服务默认已设为 qwen-plus + DashScope 兼容 URL（见 docker-compose.yml），
# 与本地 .env 不一致时以容器 environment 为准；语音条需百炼 Qwen-TTS 权限。

# 不启用 AI：注释掉下面三行或留空即可
# 方案 1：通义千问（阿里云百炼 dashscope.console.aliyun.com 获取 key）
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
OPENAI_MODEL="qwen-plus"
OPENAI_API_KEY="sk-xxx"
# 联网搜索（仅通义千问 DashScope 生效，需开通阿里云信息查询服务）
LLM_ENABLE_WEB_SEARCH="5dd5ee7e122f48479ff6d8f779a7e4a9"

# 方案 2：Ollama 本地免费（下载 ollama.com，运行 ollama pull qwen3.5:4b）
# OPENAI_BASE_URL="http://localhost:11434/v1"
# OPENAI_MODEL="qwen3.5:4b"
# OPENAI_API_KEY="ollama"

# 方案 3：Groq 云端免费（console.groq.com 注册获取 key）
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="llama-3.3-70b-versatile"
# OPENAI_API_KEY="gsk_xxx"

# 方案 4：OpenAI 官方
# OPENAI_BASE_URL=""
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_API_KEY="sk-xxx"

# ---------- Agent 聊天「语音条」----------
# TTS_PROVIDER：auto（默认）| dashscope | openai
# - auto：OPENAI_BASE_URL 含 dashscope，或 OPENAI_MODEL 名含 qwen 时，用百炼 Qwen-TTS（与 OPENAI_API_KEY 共用）
#   （Docker 若漏传 OPENAI_BASE_URL，务必用含 qwen 的模型名或显式 TTS_PROVIDER=dashscope）
# - openai：走 OpenAI /v1/audio/speech，需 OPENAI_TTS_API_KEY（或 LLM 也是官方 OpenAI 时可复用 OPENAI_API_KEY）
# TTS_PROVIDER=auto
#
# 百炼 Qwen-TTS（默认音色 Cherry，中文建议 language=Chinese）
# DASHSCOPE_API_KEY=  # 可选；不填则用 OPENAI_API_KEY
# DASHSCOPE_TTS_URL="https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation"
# 新加坡：改为 https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_TTS_MODEL="qwen3-tts-flash"
# DASHSCOPE_TTS_VOICE="Cherry"
# DASHSCOPE_TTS_LANGUAGE="Chinese"
#
# 声音复刻（创建/更新人生 Agent 且上传 voiceSampleBase64 时，向百炼注册音色，返回的 voice id 写入 voiceCloneId）
# 合成时若 voiceCloneId 非内置 Flash 预设名，则改用 VC 模型 + 该 id。
# target_model 须与合成用的 VC 模型一致（改 DASHSCOPE_VC_MODEL 时请同步百炼控制台/文档）。
# DASHSCOPE_VC_MODEL="qwen3-tts-vc-2026-01-22"
# DASHSCOPE_VOICE_ENROLL_URL="https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization"
#
# 临时排障：聊天响应会多字段 ttsDebug（勿长期 true）
# TTS_DEBUG=1

# OpenAI 语音（仅当 TTS_PROVIDER=openai 或 auto 且未匹配百炼时）
# OPENAI_TTS_API_KEY="sk-xxx"
# OPENAI_TTS_BASE_URL="https://api.openai.com/v1"
# OPENAI_TTS_MODEL="tts-1"
# OPENAI_TTS_VOICE="nova"

# ---------- 微信登录（开放平台网站应用）----------
# 在 open.weixin.qq.com 注册网站应用，获取 AppID 和 AppSecret
# WECHAT_APP_ID="wx..."
# WECHAT_APP_SECRET="..."
# 授权回调地址，须与微信控制台配置一致，不填则用 BASE_URL + /api/auth/wechat/callback
# WECHAT_REDIRECT_URI="https://yourdomain.com/api/auth/wechat/callback"
# 微信回调后重定向的前端地址，不填则从请求推断
# FRONTEND_URL="http://localhost:3000"

# ---------- 手机号登录（短信验证码）----------
# 开发环境不配置则用 Mock（验证码打印到后端日志）
# 生产环境需配置阿里云短信：RAM 创建 AccessKey，控制台申请签名和模板
# SMS_ACCESS_KEY_ID=""
# SMS_ACCESS_KEY_SECRET=""
# SMS_SIGN_NAME="您的签名"
# SMS_TEMPLATE_CODE="SMS_xxx"
# 验证码有效期，默认 5m
# PHONE_CODE_TTL="5m"

# ---------- 发信（邮箱验证码登录、找回密码）----------
# 启用条件：SMTP_HOST 与 SMTP_FROM 均非空。Go 使用 net/smtp，推荐提交端口 587（STARTTLS）。
# 未配置时：验证码/重置链接仅在开发环境打印在后端日志，不会真实发信。
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@example.com"
# SMTP_PASSWORD="客户端专用密码或授权码"
# SMTP_FROM="noreply@example.com"
# 常见：网易 163 —— smtp.163.com:465/994 可能需 implicit TLS，当前代码以 587 为主；若 587 失败可换支持 STARTTLS 的端口或后续再扩展。
# 常见：QQ 邮箱 —— smtp.qq.com:587，SMTP_USER 填 QQ 邮箱全称，密码为「授权码」。
# 常见：Gmail —— smtp.gmail.com:587，须开启应用专用密码。
# 找回密码链接有效期（默认 1h）
# PASSWORD_RESET_TTL="1h"

# ---------- 平台客服（人生 Agent）----------
# 填写一个人生 Agent 的 id 后，地图页「联系客服」会进入与该 Agent 的聊天页
# NEXT_PUBLIC_PLATFORM_SUPPORT_AGENT_ID=""
