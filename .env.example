DATABASE_URL="postgresql://postgres:password@localhost:5432/agent_fiverr?schema=public"

# 开发时若 dev 跑在 3001
NEXTAUTH_URL="http://localhost:3001"
DEMO_AGENT_BASE_URL="http://localhost:3001/api/demo-agent/invoke"

# 种子运行后会输出，加入以启用 Demo Agent 回执提交
PLATFORM_DEMO_SECRET="run-seed-to-get-this"
PLATFORM_SIGNING_SECRET="change-in-production"

# 小红的编排 Agent 内部调用 Web Analyzer / Report Builder 时使用（需小红的 API Key）
# 种子首次运行会输出 ORCHESTRATOR_BUYER_API_KEY，或使用控制台创建的 buyer 的 Key
ORCHESTRATOR_BUYER_API_KEY="sk_live_xxx"
