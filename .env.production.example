# ========== 生产环境配置模板 ==========
# 复制为 .env 后按实际密钥修改，再执行 docker compose up -d --build

# ---------- 数据库 ----------
MYSQL_ROOT_PASSWORD=请替换为强密码

# ---------- 站点公网地址（必填）----------
# 当前站点域名 brightagent.cn（HTTPS 部署后使用 https://）
# 也可用 IP（如 http://8.136.119.234:3000）；麦克风录音需 HTTPS 或 localhost
NEXTAUTH_URL=https://brightagent.cn

# 后端用于生成音频等资源的公网地址，通常与 NEXTAUTH_URL 一致
BASE_URL=https://brightagent.cn

# 微信回调后重定向地址，不填则用 NEXTAUTH_URL
FRONTEND_URL=https://brightagent.cn

# ---------- CORS（必填）----------
# 允许的前端来源，逗号分隔（根域名与 www 都写上）
CORS_ORIGINS=https://brightagent.cn,https://www.brightagent.cn

# ---------- 会话与安全（必填）----------
# 生产环境务必改为随机字符串，至少 32 位
SESSION_SECRET=请替换为随机字符串至少32位

# ---------- AI 聊天（通义千问）----------
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_API_KEY=sk-你的通义Key
LLM_ENABLE_WEB_SEARCH=你的信息查询服务ID

# ---------- 语音条 / 声音复刻 ----------
TTS_PROVIDER=dashscope
DASHSCOPE_VC_MODEL=qwen3-tts-vc-2026-01-22
DASHSCOPE_VOICE_ENROLL_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization

# ---------- 微信登录（可选）----------
# 微信开放平台「授权回调域」填 brightagent.cn（不含协议与路径）
WECHAT_APP_ID=wx你的AppID
WECHAT_APP_SECRET=你的AppSecret
WECHAT_REDIRECT_URI=https://brightagent.cn/api/auth/wechat/callback

# ---------- 手机号登录（可选）----------
SMS_ACCESS_KEY_ID=阿里云AccessKeyId
SMS_ACCESS_KEY_SECRET=阿里云AccessKeySecret
SMS_SIGN_NAME=已审核的短信签名
SMS_TEMPLATE_CODE=SMS_xxx

# ---------- 其他 ----------
PLATFORM_SIGNING_SECRET=生产环境随机字符串
ORCHESTRATOR_BUYER_API_KEY=sk_live_xxx
