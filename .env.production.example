# 生产环境变量示例
# 复制为 .env 后按实际环境修改

# MySQL（Docker Compose 中会自动组合，单独部署时填写）
MYSQL_ROOT_PASSWORD=your_secure_password_here

# 后端会话密钥（必须修改为随机字符串）
SESSION_SECRET=your-random-secret-at-least-32-characters-long

# 站点公网 URL（用户实际访问的地址）
NEXTAUTH_URL=https://your-domain.com

# CORS 允许的前端访问地址（部署后必填，否则注册/登录会失败）
# 多个用逗号分隔，如: http://8.136.119.234:3000,http://8.136.119.234,https://你的域名.com
CORS_ORIGINS=

# 可选：人生 Agent 聊天 AI
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
